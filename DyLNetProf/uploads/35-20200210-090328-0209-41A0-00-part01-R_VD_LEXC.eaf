    <TIER ANNOTATOR="charlotte chauvet" LINGUISTIC_TYPE_REF="praat" TIER_ID="*0209">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>des requins.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>et aussi des pingouins ça va dans l'eau.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>et aussi des phoques.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>bah@o moi j'ai mangé une merguez.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>j(e) te vois pas moi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>mais j(e) l'aide comme ça moi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>c'est PRENOM qui t(u) as fait ça.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts138">
