    <TIER ANNOTATOR="charlotte chauvet" LINGUISTIC_TYPE_REF="praat" TIER_ID="*1312">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>oui t(u) as raison. (il) y a des enfants qui font des bêtises ou qui font des choses qui sont dangereuses.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>alors.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts49">
                <ANNOTATION_VALUE>t(u) as raison PRENOM.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>et pourquoi elle va s(e) noyer? qu'est-c(e) qu'i(l) lui manque là au bras?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>alors nous le but du jeu.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>i(l) faut qu'on trouve.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts123">
                <ANNOTATION_VALUE>les cartes dangereuses et qu'on trouve les bonnes cartes.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>d'accord? (il) y en a elles vont toujours deux par deux.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts161">
                <ANNOTATION_VALUE>tiens ça c'est à toi tu l'as trouvé.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts180">
                <ANNOTATION_VALUE>ne crie pas ne crie pas.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts198">
                <ANNOTATION_VALUE>et l'aut(re) qu'est-c(e) qu'(il) y a sur l'autre?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts216">
                <ANNOTATION_VALUE>voilà. et bah@o t(u) as raison c'est ça.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts235">
                <ANNOTATION_VALUE>donc si on fait attention avec les bougies pour pas qu(e) ça brûle.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts254">
                <ANNOTATION_VALUE>tu peux l(e) garder. c'est toi qui l'a trouvé.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts273">
                <ANNOTATION_VALUE>non qu'est-c(e) qu'i(l) fait avec la prise là?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts292">
                <ANNOTATION_VALUE>et pourquoi c'est dangereux?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts310">
                <ANNOTATION_VALUE>parce que quoi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts328">
                <ANNOTATION_VALUE>on s'électrocute. bravo ma puce.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts347">
                <ANNOTATION_VALUE>et alors où elle est l'autre?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts366">
                <ANNOTATION_VALUE>la carte qui va avec.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts384">
                <ANNOTATION_VALUE>ah@o j(e) l'ai trouvé.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts405">
                <ANNOTATION_VALUE>PRENOM est-c(e) que t(u) avais une carte toi qui est dangereuse?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts427">
                <ANNOTATION_VALUE>attends attends PRENOM on fait chacun son tour sinon on peut pas écouter.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts446">
                <ANNOTATION_VALUE>oui qu'est-c(e) qu'i(l) met dedans?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts464">
                <ANNOTATION_VALUE>alors non là c'est pas trop la prise mais t(u) as raison ça peut.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts482">
                <ANNOTATION_VALUE>mais qu'est-c(e) qu'i(l) met là dans le.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts500">
                <ANNOTATION_VALUE>qu'est-c(e) qu'i(l) met là dans l(e) mixeur regarde bien.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts518">
                <ANNOTATION_VALUE>oui et pourquoi c'est dangereux?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts536">
                <ANNOTATION_VALUE>non c'est pas la prise. si on met les mains dans l(e) mixeur. c'est quoi l(e) mixeur vous savez?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts554">
                <ANNOTATION_VALUE>ça ça fait la soupe. alors tous les tous les légumes.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts572">
                <ANNOTATION_VALUE>qu'est-c(e) qu'i(ls) s(e) font dans l(e) mixeur. i(ls) s(e) font couper.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts590">
                <ANNOTATION_VALUE>alors nous si on met les doigts dans l(e) mixeur?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
