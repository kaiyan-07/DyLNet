    <TIER ANNOTATOR="Roché Louis" LINGUISTIC_TYPE_REF="praat" TIER_ID="*0109">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>gripsou il avait le bateau du garçon dans sa main.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a731" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts29">
                <ANNOTATION_VALUE>après le garçon i(l) voulait pas prendre le mmh@o. le bateau et après.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a732" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>et après gripsou i(l).</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a733" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>en plus gripsou il était dans les égouts.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a734" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts85">
                <ANNOTATION_VALUE>et. et gripsou il est venu et après il. et et après c'est là qu'il a qu'il a mangé le bras du garçon.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a735" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>xxx j'ai eu trop trop peur.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts123">
                <ANNOTATION_VALUE>mais en vrai il est [o]à sa maison l(e) garçon.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>et après.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a736" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>nan. il avait même pas du sang.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a737" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts178">
                <ANNOTATION_VALUE>et. et aussi xxx.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a738" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts196">
                <ANNOTATION_VALUE>et auss--.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts214">
                <ANNOTATION_VALUE>et aussi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a739" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts233">
                <ANNOTATION_VALUE>en fait il a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a740" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts252">
                <ANNOTATION_VALUE>il a tiré l(e) garçon.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a741" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts270">
                <ANNOTATION_VALUE>tu vois? gripsou il. gripsou i(l).</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a742" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts289">
                <ANNOTATION_VALUE>gripsou il a il a tiré le bras du garçon et après il l'a pris.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a743" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts309">
                <ANNOTATION_VALUE>et après i(l). et après le garçon il était à côté de gripsou et après c'est là où i(l) l'a mangé.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts329">
                <ANNOTATION_VALUE>nan il a il a mangé son bras. mais en vrai il est [o]à sa maison. mais il avait même pas [o]eu du sang.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts349">
                <ANNOTATION_VALUE>ouais. il avait un plâtre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts368">
                <ANNOTATION_VALUE>pa(r)c(e) que on l'a pas vu où (il) y avait le plâtre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
